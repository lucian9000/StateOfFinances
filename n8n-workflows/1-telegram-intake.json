    {
      "parameters": {
        "jsCode": "const trig = $('Telegram Trigger').item.json;\nconst msg = trig.message || {};\nconst pendingItems = $input.all();\nconst pending = (pendingItems.length && pendingItems[0].json && pendingItems[0].json.id) ? pendingItems[0].json : null;\n\nconst text = (msg.text || '').trim();\nconst hasPhoto = Array.isArray(msg.photo) && msg.photo.length > 0;\nconst numMatch = text.replace(/^[Rr]\\s*/, '').match(/^\\d+(\\.\\d+)?$/);\nconst amountLinePattern = /\\bR?\\s?\\d+(\\.\\d{1,2})?\\.?\\s*$/i;\nconst anyNumber = text.split('\\n').some((line) => amountLinePattern.test(line.trim()));\nconst isBalance = /\\bbalance\\b/i.test(text);\n\n// \"income <amount>\" records a POSITIVE income row (available funds), never a spend.\nconst isIncomeAdd = /^\\s*income\\b/i.test(text);\nlet incomeAddAmount = null;\nif (isIncomeAdd) {\n  const m = text.replace(/,/g, '').replace(/^\\s*income\\b/i, '').match(/R?\\s*(\\d+(?:\\.\\d+)?)/i);\n  if (m) incomeAddAmount = parseFloat(m[1]);\n}\n\nlet route = 'chat';\nif (pending && numMatch) {\n  route = 'income';\n} else if (hasPhoto) {\n  route = 'photo';\n} else if (isIncomeAdd && incomeAddAmount != null) {\n  route = 'income_add';\n} else if (isBalance && anyNumber) {\n  route = 'balance';\n} else if (anyNumber) {\n  route = 'text';\n}\n\nreturn [{\n  json: {\n    route,\n    chatId: msg.chat.id,\n    messageId: msg.message_id,\n    text,\n    pendingIncomeId: pending ? pending.id : null,\n    pendingIncomeType: pending ? pending.type : null,\n    incomeAmount: numMatch ? parseFloat(numMatch[0]) : null,\n    incomeAddAmount,\n    photoFileId: hasPhoto ? msg.photo[msg.photo.length - 1].file_id : null,\n  }\n}];"
      },
