    {
      "parameters": {
        "jsCode": "const route = $json;\n// Same rule as \"Route Message\": a line only counts as an expense line when\n// the amount is the LAST thing on it, not just any digit anywhere - keeps\n// this split consistent with the routing decision that got us here.\nconst amountLinePattern = /\\bR?\\s?\\d+(\\.\\d{1,2})?\\.?\\s*$/i;\nconst lines = route.text.split('\\n').map((l) => l.trim()).filter(Boolean);\nconst expenseLines = lines.filter((l) => amountLinePattern.test(l));\n// Multi-line messages (\"log these: ...\") become one item per expense line,\n// so each gets its own classify + insert + confirmation instead of the\n// whole message being crammed into a single transaction. Single-line\n// messages behave exactly as before (one line in, one item out).\nconst sourceLines = expenseLines.length ? expenseLines : [route.text];\n\nreturn sourceLines.map((line) => {\n  const amountMatch = line.match(/\\d+(\\.\\d+)?/);\n  return {\n    json: {\n      text: line,\n      amount: amountMatch ? parseFloat(amountMatch[0]) : null,\n      date: null,\n      raw_ocr_text: null,\n      chatId: route.chatId,\n      messageId: route.messageId,\n      source: 'manual',\n    },\n  };\n});"
      },
