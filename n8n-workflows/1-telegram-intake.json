    {
      "parameters": {
        "jsCode": "const r = $json;\nconst lines = [];\nif (r.reconciled && r.reconciled.length) {\n  lines.push('✅ Ticked off your grocery list:');\n  for (const x of r.reconciled) lines.push(`  • ${x.item_name}${x.actual_price != null ? ' — R' + Number(x.actual_price).toFixed(2) : ''}`);\n}\nif (r.uncertain && r.uncertain.length) {\n  for (const u of r.uncertain) lines.push(`❓ Slip had \"${u.ocr_text}\" — maybe \"${u.candidate_item_name}\"? Not sure, so I left it on the list. Tick it on the dashboard if that's it.`);\n}\nif (lines.length === 0) return [];\nreturn [{ json: { message: lines.join('\\n') } }];"
      },
