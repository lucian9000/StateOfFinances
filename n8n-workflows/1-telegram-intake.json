              "id": "949fd1cc-d586-4ca3-bd4a-ea904fdda811",
              "leftValue": "={{ $json.route }}",
              "rightValue": "income",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "706c8584-4c57-4fde-a359-dbbc155edfd1",
