    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, pay_date, type FROM income WHERE confirmed_zar IS NULL ORDER BY pay_date DESC LIMIT 1",
        "options": {}
      },
      "id": "2bd797d8-c240-4343-9452-14b1e6ca05f5",
      "name": "Get Pending Income",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [-1180, 300],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": { "id": "syWj4Ccfmwep9ePX", "name": "Budget Postgres" }
      }
    },
    {
      "parameters": {
        "jsCode": "const trig = $('Telegram Trigger').item.json;\nconst msg = trig.message || {};\nconst pendingItems = $input.all();\nconst pending = (pendingItems.length && pendingItems[0].json && pendingItems[0].json.id) ? pendingItems[0].json : null;\n\nconst text = (msg.text || '').trim();\nconst hasPhoto = Array.isArray(msg.photo) && msg.photo.length > 0;\nconst numMatch = text.replace(/^[Rr]\\s*/, '').match(/^\\d+(\\.\\d+)?$/);\nconst anyNumber = text.match(/\\d+(\\.\\d+)?/);\n\n// chat is the default: anything that isn't an income reply, a photo,\n// or a text containing an amount goes to the OpenClaw agent for a\n// conversational reply instead of being force-parsed as a transaction.\nlet route = 'chat';\nif (pending && numMatch) {\n  route = 'income';\n} else if (hasPhoto) {\n  route = 'photo';\n} else if (anyNumber) {\n  route = 'text';\n}\n\nreturn [{\n  json: {\n    route,\n    chatId: msg.chat.id,\n    messageId: msg.message_id,\n    text,\n    pendingIncomeId: pending ? pending.id : null,\n    pendingIncomeType: pending ? pending.type : null,\n    incomeAmount: numMatch ? parseFloat(numMatch[0]) : null,\n    photoFileId: hasPhoto ? msg.photo[msg.photo.length - 1].file_id : null,\n  }\n}];"
      },
      "id": "ee91187c-5191-4d5b-9fbc-06a33f71e59c",
      "name": "Route Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-960, 300]
    },
    {
      "parameters": {
        "conditions": {
